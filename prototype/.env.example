# Anthropic API — used server-side only via the Vite dev middleware (never sent to the browser)
ANTHROPIC_API_KEY=your-anthropic-api-key

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Strava app credentials — strava.com/settings/api
# ⚠️ Client secret must move to a server function before public deployment
VITE_STRAVA_CLIENT_ID=your-client-id
VITE_STRAVA_CLIENT_SECRET=your-client-secret

# Withings app credentials — account.withings.com/partner/dashboard
# ⚠️ Same prototype caveat — move to Edge Function before public deployment
VITE_WITHINGS_CLIENT_ID=your-withings-client-id
VITE_WITHINGS_CLIENT_SECRET=your-withings-client-secret
